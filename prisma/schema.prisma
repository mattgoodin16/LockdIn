generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Sex {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum GoalType {
  FAT_LOSS
  MUSCLE_GAIN
  STRENGTH
  MAINTENANCE
  GENERAL_FITNESS
}

enum TrainingLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum EquipmentType {
  FULL_GYM
  HOME_GYM
  DUMBBELLS_ONLY
  BODYWEIGHT_ONLY
  MINIMAL
  CUSTOM
}

enum DietaryPreference {
  OMNIVORE
  VEGETARIAN
  VEGAN
  PESCATARIAN
  KETO
  LOW_CARB
  MEDITERRANEAN
  CUSTOM
}

enum NotificationTone {
  AGGRESSIVE
  ENCOURAGING
  DISCIPLINED
  COACH
  MINIMAL
}

enum ReminderCategory {
  WORKOUT
  NUTRITION
  CHECK_IN
  MILESTONE
}

enum PlanStatus {
  ACTIVE
  ARCHIVED
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum MilestoneStatus {
  UPCOMING
  ON_TRACK
  AHEAD
  BEHIND
  COMPLETED
}

enum TrendDirection {
  UP
  DOWN
  STABLE
}

enum VisibilityLevel {
  PUBLIC
  FRIENDS_ONLY
  PRIVATE
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile            UserProfile?
  goalProfile        GoalProfile?
  workoutPlans       WorkoutPlan[]
  nutritionPlans     NutritionPlan[]
  workoutLogs        WorkoutLog[]
  bodyMetricLogs     BodyMetricLog[]
  nutritionLogs      NutritionLog[]
  progressPhotos     ProgressPhoto[]
  progressCheckIns   ProgressCheckIn[]
  adherenceSnapshots AdherenceSnapshot[]
  milestones         Milestone[]
  weeklyRecaps       WeeklyRecap[]
  groceryLists       GroceryList[]
  privacySettings    PrivacySettings?
  notificationPref   NotificationPreference?

  sentFriendRequests     FriendConnection[] @relation("sender")
  receivedFriendRequests FriendConnection[] @relation("receiver")

  accounts Account[]
  sessions Session[]
}

model UserProfile {
  id                      String             @id @default(cuid())
  userId                  String             @unique
  age                     Int?
  sex                     Sex?
  heightCm                Float?
  weightKg                Float?
  bodyAreasToPrioritize   String[]
  preferredWorkoutStyle   String?
  seriousnessLevel        Int?
  activityLevel           String?
  consistencyLevel        String?
  injuries                String[]
  mobilityLimitations     String[]
  exercisesToAvoid        String[]
  recoveryConcerns        String[]
  dietaryPreference       DietaryPreference?
  foodDislikes            String[]
  foodAllergies           String[]
  mealFrequencyPreference Int?
  caloriePreference       Int?
  onboardingCompleted     Boolean            @default(false)
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GoalProfile {
  id                        String        @id @default(cuid())
  userId                    String        @unique
  goalType                  GoalType
  timelineWeeks             Int
  targetWeightKg            Float?
  targetWaistCm             Float?
  targetStrengthMetric      String?
  targetWorkoutDaysPerWeek  Int
  sessionLengthMinutes      Int
  trainingLevel             TrainingLevel
  equipmentType             EquipmentType
  customEquipment           String[]
  workoutsPerWeek           Int
  notificationTimeLocal     String?
  remindersEnabledWorkout   Boolean       @default(true)
  remindersEnabledNutrition Boolean       @default(true)
  remindersEnabledCheckIn   Boolean       @default(true)
  remindersEnabledMilestone Boolean       @default(true)
  createdAt                 DateTime      @default(now())
  updatedAt                 DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutPlan {
  id                String     @id @default(cuid())
  userId            String
  title             String
  objective         String
  status            PlanStatus @default(ACTIVE)
  weekStart         DateTime
  adaptationSummary String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  days            WorkoutDay[]
  logs            WorkoutLog[]
  adaptiveChanges AdaptivePlanChange[]
}

model WorkoutDay {
  id            String   @id @default(cuid())
  workoutPlanId String
  dayIndex      Int
  dayLabel      String
  focus         String
  warmUp        String?
  cooldown      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workoutPlan   WorkoutPlan            @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  prescriptions ExercisePrescription[]
}

model Exercise {
  id                  String        @id @default(cuid())
  slug                String        @unique
  name                String
  description         String
  executionNotes      String[]
  muscleGroups        String[]
  movementPattern     String
  equipment           String[]
  difficulty          TrainingLevel
  injuryFlags         String[]
  tempoRecommendation String?
  isCompound          Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  prescriptions     ExercisePrescription[]
  substitutionsFrom ExerciseSubstitution[] @relation("fromExercise")
  substitutionsTo   ExerciseSubstitution[] @relation("toExercise")
}

model ExercisePrescription {
  id               String   @id @default(cuid())
  workoutDayId     String
  exerciseId       String
  orderIndex       Int
  sets             Int
  reps             String
  restSeconds      Int
  progressionRule  String
  substitutionHint String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workoutDay WorkoutDay @relation(fields: [workoutDayId], references: [id], onDelete: Cascade)
  exercise   Exercise   @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
}

model ExerciseSubstitution {
  id             String   @id @default(cuid())
  fromExerciseId String
  toExerciseId   String
  reason         String
  priority       Int      @default(1)
  createdAt      DateTime @default(now())

  fromExercise Exercise @relation("fromExercise", fields: [fromExerciseId], references: [id], onDelete: Cascade)
  toExercise   Exercise @relation("toExercise", fields: [toExerciseId], references: [id], onDelete: Cascade)

  @@unique([fromExerciseId, toExerciseId])
}

model NutritionPlan {
  id                  String   @id @default(cuid())
  userId              String
  calories            Int
  proteinGrams        Int
  carbsGrams          Int
  fatsGrams           Int
  hydrationLiters     Float
  mealStructure       String[]
  preWorkoutGuidance  String?
  postWorkoutGuidance String?
  notes               String[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  groceryLists GroceryList[]
}

model GroceryList {
  id              String   @id @default(cuid())
  userId          String
  nutritionPlanId String
  style           String
  weekOf          DateTime
  proteinItems    String[]
  carbItems       String[]
  fatItems        String[]
  fruitItems      String[]
  vegetableItems  String[]
  snackItems      String[]
  hydrationItems  String[]
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  nutritionPlan NutritionPlan @relation(fields: [nutritionPlanId], references: [id], onDelete: Cascade)
}

model WorkoutLog {
  id                String   @id @default(cuid())
  userId            String
  workoutPlanId     String?
  workoutDayId      String?
  completed         Boolean
  completionPercent Int
  difficultyRating  Int?
  skippedReason     String?
  notes             String?
  performedAt       DateTime
  createdAt         DateTime @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  workoutPlan WorkoutPlan? @relation(fields: [workoutPlanId], references: [id], onDelete: SetNull)
}

model BodyMetricLog {
  id             String         @id @default(cuid())
  userId         String
  loggedAt       DateTime
  weightKg       Float?
  waistCm        Float?
  bodyFatPercent Float?
  energyLevel    Int?
  sleepQuality   Int?
  soreness       Int?
  hunger         Int?
  notes          String?
  trendDirection TrendDirection @default(STABLE)
  createdAt      DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NutritionLog {
  id                      String   @id @default(cuid())
  userId                  String
  loggedAt                DateTime
  macroAdherencePercent   Int
  calorieAdherencePercent Int
  waterLiters             Float?
  notes                   String?
  createdAt               DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressPhoto {
  id        String   @id @default(cuid())
  userId    String
  label     String
  imageUrl  String
  takenAt   DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProgressCheckIn {
  id                  String    @id @default(cuid())
  userId              String
  dueDate             DateTime
  completedAt         DateTime?
  workoutDifficulty   Int
  energy              Int
  sleepQuality        Int
  hunger              Int
  soreness            Int
  stress              Int
  confidence          Int
  motivation          Int
  intensityPreference String?
  painFlag            Boolean   @default(false)
  painNotes           String?
  flexibilityRequest  String?
  createdAt           DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdherenceSnapshot {
  id                      String   @id @default(cuid())
  userId                  String
  snapshotDate            DateTime
  workoutsPlanned         Int
  workoutsCompleted       Int
  nutritionAdherenceAvg   Int
  checkInCompletionRate   Int
  recoveryInputRate       Int
  streakDays              Int
  weeklyAdherencePercent  Int
  monthlyConsistencyScore Int
  createdAt               DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Milestone {
  id           String          @id @default(cuid())
  userId       String
  title        String
  description  String
  targetDate   DateTime
  metricType   String
  targetValue  Float
  currentValue Float?
  status       MilestoneStatus @default(UPCOMING)
  createdAt    DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeeklyRecap {
  id                   String   @id @default(cuid())
  userId               String
  weekStart            DateTime
  workoutsCompleted    Int
  workoutsPlanned      Int
  adherenceScore       Int
  streak               Int
  bodyTrendSummary     String
  milestoneProgress    String
  topAchievement       String
  nextFocus            String
  shareableCardPayload Json
  createdAt            DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model FriendConnection {
  id         String       @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  sender   User @relation("sender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model NotificationPreference {
  id                String           @id @default(cuid())
  userId            String           @unique
  tone              NotificationTone @default(COACH)
  preferredTime     String
  workoutReminder   Boolean          @default(true)
  nutritionReminder Boolean          @default(true)
  checkInReminder   Boolean          @default(true)
  milestoneReminder Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PrivacySettings {
  id                        String          @id @default(cuid())
  userId                    String          @unique
  profileVisibility         VisibilityLevel @default(PRIVATE)
  showConsistencyToFriends  Boolean         @default(true)
  shareWeeklyRecapByDefault Boolean         @default(false)
  discoverableProfile       Boolean         @default(false)
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AdaptivePlanChange {
  id            String   @id @default(cuid())
  workoutPlanId String
  changedAt     DateTime @default(now())
  title         String
  reason        String
  action        String

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}
